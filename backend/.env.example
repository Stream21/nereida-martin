PORT=3000
DATABASE_URL=postgresql://user:password@host:5432/nere_studio

# URL pública (en Render se rellena automáticamente con RENDER_EXTERNAL_URL)
BACKEND_URL=https://nere-studio.onrender.com
FRONTEND_URL=https://nere-studio.onrender.com

# Google Calendar API (run: node scripts/google-auth.js)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary
GOOGLE_WEB_EVENT_COLOR_ID=7

# Primer día en que la web acepta reservas nuevas (YYYY-MM-DD)
BOOKING_START_DATE=2026-07-01

# Google Calendar push sync (HTTPS público requerido)
GOOGLE_WEBHOOK_URL=https://nere-studio.onrender.com/api/webhooks/google-calendar
GOOGLE_WEBHOOK_SECRET=

# Gmail SMTP (App Password: https://myaccount.google.com/apppasswords)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Cron security (Render puede generarlo automáticamente)
CRON_SECRET=
